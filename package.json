{
  "name": "hermes-handler",
  "version": "1.0.3",
  "description": "HermesHandler is a lightweight, framework-agnostic message router for browser extensions and event-driven systems, with strict {ok,result,error} envelopes, timeouts, cooperative cancellation, and safe normalization. Ideal for reliable LLM agent backbones.",
  "license": "SEE LICENSE IN LICENSE",
  "author": "WATT3D <WATT3D@protonmail.com>",
  "packageManager": "pnpm@10.33.2",
  "homepage": "https://github.com/iWhatty/hermes-handler#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iWhatty/hermes-handler.git"
  },
  "bugs": {
    "url": "https://github.com/iWhatty/hermes-handler/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./transports/postmessage": {
      "types": "./dist/transports/postmessage.d.ts",
      "import": "./dist/transports/postmessage.js"
    },
    "./transports/chrome-runtime": {
      "types": "./dist/transports/chrome-runtime.d.ts",
      "import": "./dist/transports/chrome-runtime.js"
    },
    "./transports/broadcast-channel": {
      "types": "./dist/transports/broadcast-channel.d.ts",
      "import": "./dist/transports/broadcast-channel.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "ADDITIONAL_TERMS.md",
    "robots.txt"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "pnpm run clean && pnpm run build:js && pnpm run build:types",
    "build:js": "mkdir -p dist && cp -R src/. dist/",
    "build:types": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "test": "vitest run && pnpm run test:types",
    "test:types": "tsc -p tsconfig.test-types.json",
    "prepublishOnly": "pnpm run build && pnpm test"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  },
  "keywords": [
    "javascript",
    "browser-extension",
    "webextension",
    "message-router",
    "event-driven",
    "llm",
    "agent",
    "runtime",
    "router",
    "abortsignal"
  ]
}
